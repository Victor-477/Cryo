// Demonstration of the self-hosted lexer running on the Pyro VM.
//   python burnout/cryoc.py cryo/selfhost/lex_demo.cryo --backend pyro --run
import "lexer.cryo"

tokenize("fn f(int n) -> number ={ /* bloco */ number x = 3.14; int c = n * 2; if (c >= 10 && n != 0) { c = c - 1; } return x; } string s = \"Cryo\";");
