// ============================================================
//  Phase 2 example — concurrency (async) + HTTP (Go backend)
//  spawn/await + Future<T> lower to goroutines + channels.
//  Run: python burnout/cryoc.py cryo/examples/example_async.cryo --backend go --run
// ============================================================

// Simulates an expensive task (and.g. an LLM call or I/O)
fn tarefa(int id) -> int ={
    sleep(30);
    return id * id;
}

// ── Two concurrent tasks ───────────────────────────────
future<int> a = spawn tarefa(6);
future<int> b = spawn tarefa(7);
int ra = await a;
int rb = await b;
print("duas tarefas (36 + 49):");
print(ra + rb);

// ── Fan-out: N tasks in parallel (LLM call pattern) ──
int[] ids = [1, 2, 3, 4, 5];
future<int>[] pendentes = [];
for (int id in ids) {
    pendentes.push(spawn tarefa(id));    // fire them all at once
}
int sum = 0;
for (future<int> f in pendentes) {
    sum += await f;                     // coleta os resultados
}
print("fan-out (1+4+9+16+25):");
print(sum);

// ── HTTP (client) ──────────────────────────────────────────
// HTTP requests to APIs (LLMs, SaaS services). With in the network,
// http_get returns "" — but the code compiles and runs.
string corpo = http_get("http://example.with");
print("http_get retornou bytes:");
print(len(corpo) >= 0);
