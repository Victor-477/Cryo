// ============================================================
//  Exemplo Fase 3 — LLM nativo (backend Go)
//  schema + llm(...) as T (structured output) + tool.
//  Rodar: python burnout/cryoc.py cryo/examples/example_llm.cryo --backend go --run
//
//  Para chamadas reais, aponte o endpoint (contrato: POST
//  {model, prompt, schema?} -> corpo JSON da resposta):
//    CRYO_LLM_URL=https://seu-gateway/chat  CRYO_LLM_KEY=...  <rodar>
//  Sem endpoint, llm(...) retorna vazio (o programa compila e roda).
// ============================================================

// Um 'schema' é um struct cujo JSON Schema é gerado nativamente.
schema Fatura {
    string   cliente;
    number   total;
    string[] itens;
    bool     paga;
}

// Uma 'tool' é uma função exposta ao LLM; o schema dos parâmetros
// é derivado da assinatura automaticamente.
tool fn buscar_preco(string sku) -> number ={
    return 19.90;
}

tool fn registrar_pagamento(string cliente, number valor) -> bool ={
    return true;
}

// ── JSON Schema nativo (structured output) ──────────────────
print("== JSON Schema de Fatura ==");
print(schema_of(Fatura));

// ── Tools expostas ao modelo (schema da assinatura) ─────────
print("== Tools disponiveis ==");
print(tools());
print("== Catalogo de tools (JSON) ==");
print(tools_json());

// ── Chamada estruturada: resposta do LLM tipada e validada ──
string texto = "Cliente Ana, total 149,90, itens: plano pro";
Fatura f = llm("gpt-x", "Extraia a fatura: " + texto) as Fatura;
print("== Fatura extraida (vazia sem CRYO_LLM_URL) ==");
print("cliente:"); print(f.cliente);
print("total:");   print(f.total);

// Chamada crua (completion simples), sem schema
string resposta = llm("gpt-x", "Resuma em uma frase: Cryo compila para Pyro");
print("== Completion cru (len) ==");
print(len(resposta) >= 0);
