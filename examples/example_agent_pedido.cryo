// ============================================================
//  Phase 3 example — e-commerce agent with SEVERAL tools
//
//  A realistic agentic flow: the model chains 6 tools to
//  build an order — look up customer, look up product (returns
//  a struct), check stock, compute shipping, apply a coupon
//  and create the order — then summarize the result.
//
//  Run (with a real LLM via gateway, or the test mock):
//    CRYO_LLM_URL=http://127.0.0.1:8801 \
//      python burnout/cryoc.py cryo/examples/example_agent_pedido.cryo --backend go --run
// ============================================================

struct Produto { string nome; number preco; }

// ── Tools exposed to the agent (schema derived from the signature) ──

tool fn buscar_cliente(string email) -> string ={
    if (email == "ana@loja.com") { return "Ana Silva"; }
    return "Cliente Desconhecido";
}

tool fn buscar_produto(string sku) -> Produto ={
    if (sku == "SKU-1") { return new Produto { nome: "Fone Bluetooth", preco: 129.90 }; }
    if (sku == "SKU-2") { return new Produto { nome: "Teclado Mecanico", preco: 249.90 }; }
    return new Produto { nome: "Desconhecido", preco: 0.0 };
}

tool fn verificar_estoque(string sku) -> int ={
    if (sku == "SKU-1") { return 42; }
    if (sku == "SKU-2") { return 7; }
    return 0;
}

tool fn calcular_frete(string cep, int qtd) -> number ={
    return 12.50 + qtd * 6.00;    // base + por item
}

tool fn aplicar_cupom(number total, string cupom) -> number ={
    if (cupom == "PROMO10") { return total * 0.90; }   // 10% off
    if (cupom == "FRETEGRATIS") { return total; }
    return total;
}

tool fn criar_pedido(string cliente, number total) -> string ={
    return "PED-1007";
}

// ── O agente decide quais tools chamar, em qual ordem ────────
string resposta = agent("gpt-x",
    "Faça um pedido para ana@loja.com: 2 unidades do SKU-1, " +
    "cupom PROMO10, entrega no CEP 01000-000. Confirme o total e o estoque.");

print("== Tools disponiveis para o agente ==");
print(tools());
print("== Resposta do agente ==");
print(resposta);
