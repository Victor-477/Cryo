// ============================================================
//  Exemplo — stdlib do Cryo no bytecode Pyro (VM)
//
//  Demonstra o backend pyro reforçado: enum, matemática,
//  conversões, funções de string e remove() — tudo executando
//  na VM Pyro via a instrução NATIVE da ISA.
//
//  Rodar:
//    python burnout/cryoc.py cryo/examples/example_stdlib.cryo --backend pyro --run
//  (o mesmo programa roda também com --backend go e --backend node)
// ============================================================

enum Estado { PENDENTE, ATIVO, ENCERRADO }

fn hipotenusa(number a, number b) -> number ={
    return sqrt(pow(a, 2.0) + pow(b, 2.0));
}

fn slug(string titulo) -> string ={
    return lower(replace(trim(titulo), " ", "-"));
}

// ── matemática ──────────────────────────────────────────────
print("hipotenusa(3,4):");   print(hipotenusa(3.0, 4.0));
print("abs(-9) min(2,5) max(2,5):");
print(abs(0 - 9)); print(min(2, 5)); print(max(2, 5));
print("floor/ceil/round de 2.5:");
print(floor(2.5)); print(ceil(2.5)); print(round(2.5));

// ── conversões ──────────────────────────────────────────────
int    lidos = to_int("128");
number taxa  = to_number("0.75");
print("128 * 0.75 =");
print(to_number(to_string(lidos)) * taxa);

// ── strings ─────────────────────────────────────────────────
string titulo = "  Cryo Compila Para Pyro  ";
print("slug:");            print(slug(titulo));
print("contains 'Pyro'?"); print(contains(titulo, "Pyro"));
print("find('Pyro'):");    print(find(trim(titulo), "Pyro"));
print("substr(0,4):");     print(substr(trim(titulo), 0, 4));

string csv = "norte,sul,leste,oeste";
string[] direcoes = split(csv, ",");
print("split -> len:");    print(len(direcoes));
print("join(' > '):");     print(join(direcoes, " > "));

// ── enum + switch ───────────────────────────────────────────
Estado e = Estado_ATIVO;
switch (e) {
    case Estado_PENDENTE: print("pendente");
    case Estado_ATIVO:    print("ativo!");
    default:              print("encerrado");
}

// ── map + remove ────────────────────────────────────────────
map<string, int> sessoes = { "ana": 3, "bia": 7 };
remove(sessoes, "ana");
print("sessoes de ana removidas?");
print(!has(sessoes, "ana"));

assert(slug(titulo) == "cryo-compila-para-pyro", "slug incorreto");
assert(to_int("128") == 128, "to_int incorreto");
assert(len(direcoes) == 4, "split incorreto");
print("stdlib ok nos tres backends");
