// ============================================================
//  Exemplo Cryo v0.7 — recursos para SaaS/LLM (backend Go)
//  Demonstra: mapas, JSON nativo (struct<->json) e opcionais.
//  Rodar: python cryoc.py examples/example_saas.cryo --run
// ============================================================

struct Produto {
    string sku;
    string nome;
    number preco;
    bool   ativo;
}

struct RespostaAPI {
    bool   ok;
    string mensagem;
    int    total;
}

// ── Cache em memória com mapa ───────────────────────────────
fn buscarPreco(map<string, number> tabela, string sku) -> number? ={
    if (has(tabela, sku)) {
        return tabela[sku];
    }
    return null;
}

// ── Programa principal ──────────────────────────────────────

// Tabela de preços (map) — típico de um serviço SaaS
map<string, number> precos = {
    "SKU-1": 19.90,
    "SKU-2": 49.90,
    "SKU-3": 5.00
};
precos["SKU-4"] = 99.90;

// Lookup com opcional (null-safety): sem panics por chave ausente
number? achado = buscarPreco(precos, "SKU-2");
number precoFinal = achado ?? 0.0;

number? ausente = buscarPreco(precos, "SKU-999");
number fallback = ausente ?? -1.0;

// Total do catálogo iterando o mapa
number soma = 0.0;
for (string k in keys(precos)) {
    soma += precos[k];
}

// Serialização JSON de um struct (payload de API/LLM)
Produto p = new Produto {
    sku: "SKU-2",
    nome: "Plano Pro",
    preco: precoFinal,
    ativo: true
};
string payload = json_encode(p);

// Desserialização tipada (ex.: resposta de um LLM em JSON)
string entrada = "{\"ok\": true, \"mensagem\": \"criado\", \"total\": 4}";
RespostaAPI r = json_decode(entrada) as RespostaAPI;

print("preco SKU-2:");      print(precoFinal);
print("SKU ausente (fallback):"); print(fallback);
print("soma do catalogo:"); print(soma);
print("payload JSON:");     print(payload);
print("resposta.ok:");      print(r.ok);
print("resposta.mensagem:"); print(r.mensagem);
print("resposta.total:");   print(r.total);
