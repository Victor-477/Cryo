// ============================================================
//  Cryo v0.7 example — SaaS/LLM features (Go backend)
//  Shows: maps, native JSON (struct<->json) and optionals.
//  Run: python cryoc.py examples/example_saas.cryo --run
// ============================================================

struct Produto {
    string sku;
    string name;
    number preco;
    bool   active;
}

struct RespostaAPI {
    bool   ok;
    string mensagem;
    int    total;
}

// ── In-memory cache with a map ───────────────────────────────
fn buscarPreco(map<string, number> tabela, string sku) -> number? ={
    if (has(tabela, sku)) {
        return tabela[sku];
    }
    return null;
}

// ── Main program ──────────────────────────────────────

// Price table (map) — typical of a SaaS service
map<string, number> precos = {
    "SKU-1": 19.90,
    "SKU-2": 49.90,
    "SKU-3": 5.00
};
precos["SKU-4"] = 99.90;

// Lookup with an optional (null-safety): in the panics on missing key
number? achado = buscarPreco(precos, "SKU-2");
number precoFinal = achado ?? 0.0;

number? ausente = buscarPreco(precos, "SKU-999");
number fallback = ausente ?? -1.0;

// Catalog total by iterating the map
number sum = 0.0;
for (string k in keys(precos)) {
    sum += precos[k];
}

// JSON serialization of a struct (API/LLM payload)
Produto p = new Produto {
    sku: "SKU-2",
    name: "Plano Pro",
    preco: precoFinal,
    active: true
};
string payload = json_encode(p);

// Typed deserialization (and.g. an LLM response in JSON)
string input = "{\"ok\": true, \"mensagem\": \"criado\", \"total\": 4}";
RespostaAPI r = json_decode(input) as RespostaAPI;

print("preco SKU-2:");      print(precoFinal);
print("SKU ausente (fallback):"); print(fallback);
print("sum do catalogo:"); print(sum);
print("payload JSON:");     print(payload);
print("resposta.ok:");      print(r.ok);
print("resposta.mensagem:"); print(r.mensagem);
print("resposta.total:");   print(r.total);
