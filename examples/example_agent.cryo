// ============================================================
//  Phase 3 example — agent loop (tool-calling)
//
//  The agent talks to the LLM in a loop: the model asks for a tool,
//  the runtime RUNS the real `tool` function, returns the result, and
//  repeats until the final answer. Endpoint contract:
//    POST {model, messages, tools}
//      -> {"tool_call": {"name": "...", "arguments": {...}}}   (pede tool)
//      -> {"content": "final answer"}                        (ends)
//
//  Run with a real LLM (or a compatible gateway):
//    CRYO_LLM_URL=https://seu-gateway/chat CRYO_LLM_KEY=... \
//      python burnout/cryoc.py cryo/examples/example_agent.cryo --backend go --run
//  Without CRYO_LLM_URL, the agent returns empty (compiles and runs).
// ============================================================

// Tools the agent can call. The parameter schema is
// derived from the signature automatically.
tool fn buscar_preco(string sku) -> number ={
    if (sku == "SKU-1") { return 19.90; }
    if (sku == "SKU-2") { return 49.90; }
    return 0.0;
}

tool fn aplicar_desconto(number preco, number pct) -> number ={
    return preco - (preco * pct / 100.0);
}

// The agent loop: the model decides which tools to call and when to stop.
string resposta = agent("gpt-x",
    "Qual o preco do SKU-1 com 10% de desconto?");

print("== resposta do agente ==");
print(resposta);
